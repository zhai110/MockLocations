<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="10dp">

        <!-- 坐标系选择 -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/divider">

        <RadioGroup
            android:id="@+id/radio_group_coordinate_system"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="4dp">

            <RadioButton
                android:id="@+id/radio_gcj02"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:button="@null"
                android:background="@drawable/bg_radio_button_selector"
                android:gravity="center"
                android:paddingVertical="5dp"
                android:text="GCJ-02"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="4dp"
                android:background="@color/divider" />

            <RadioButton
                android:id="@+id/radio_wgs84"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:button="@null"
                android:background="@drawable/bg_radio_button_selector"
                android:gravity="center"
                android:paddingVertical="5dp"
                android:text="WGS-84"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginVertical="4dp"
                android:background="@color/divider" />

            <RadioButton
                android:id="@+id/radio_bd09"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:button="@null"
                android:background="@drawable/bg_radio_button_selector"
                android:gravity="center"
                android:paddingVertical="5dp"
                android:text="BD-09"
                android:textColor="@color/text_primary"
                android:textSize="12sp" />

        </RadioGroup>
        </com.google.android.material.card.MaterialCardView>

        <!-- 纬度输入 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_latitude"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="纬度"
            app:boxCornerRadiusBottomEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusTopStart="10dp"
            app:errorEnabled="true"
            app:helperText="-90.0 ~ 90.0"
            app:helperTextTextColor="@color/text_hint"
            app:prefixText="Lat"
            app:prefixTextColor="@color/primary"
            app:startIconDrawable="@drawable/ic_position"
            app:startIconTint="@color/primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_latitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 经度输入 -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layout_longitude"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:hint="经度"
            app:boxCornerRadiusBottomEnd="10dp"
            app:boxCornerRadiusBottomStart="10dp"
            app:boxCornerRadiusTopEnd="10dp"
            app:boxCornerRadiusTopStart="10dp"
            app:errorEnabled="true"
            app:helperText="-180.0 ~ 180.0"
            app:helperTextTextColor="@color/text_hint"
            app:prefixText="Lng"
            app:prefixTextColor="@color/primary"
            app:startIconDrawable="@drawable/ic_position"
            app:startIconTint="@color/primary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_longitude"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal|numberSigned"
                android:textSize="15sp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- 实时验证提示 -->
        <TextView
            android:id="@+id/text_validation_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="center"
            android:text="请输入有效的坐标"
            android:textColor="@color/text_hint"
            android:textSize="10sp"
            android:visibility="gone" />

</LinearLayout>

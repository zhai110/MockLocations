<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="false"
    tools:context=".ui.main.MainActivity">

    <!-- 地图区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.amap.api.maps.MapView
            android:id="@+id/map_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fitsSystemWindows="false" />
    </FrameLayout>

    <!-- 搜索栏 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/search_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:layout_marginTop="60dp"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="16dp"
        app:strokeWidth="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 搜索输入区域 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_hint" />

                    <EditText
                        android:id="@+id/search_edit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="@string/search_hint"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- 搜索加载指示器和关闭按钮 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center_vertical"
                    android:layout_marginEnd="12dp"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ProgressBar
                        android:id="@+id/search_progress"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:indeterminateTint="@color/primary"
                        android:visibility="gone" />

                    <ImageButton
                        android:id="@+id/search_clear_btn"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_close"
                        android:contentDescription="@string/clear_search"
                        android:padding="6dp"
                        app:tint="@color/text_secondary"
                        android:visibility="gone" />
                </LinearLayout>
            </FrameLayout>

            <!-- 搜索结果列表（默认隐藏） -->
            <FrameLayout
                android:id="@+id/search_result_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone">

                <!-- 顶部分隔线 -->
                <View
                    android:id="@+id/search_top_divider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_gravity="top" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/search_result_list"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:background="@color/surface"
                    android:overScrollMode="never"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />
            </FrameLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 路线控制栏（默认隐藏，路线模式时显示在地图上方） -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/route_control_card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="108dp"
        android:visibility="gone"
        app:cardBackgroundColor="?attr/colorSurface"
        app:cardCornerRadius="20dp"
        app:strokeWidth="0dp"
        app:cardElevation="4dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="6dp"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/route_play_fab_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_play"
                android:contentDescription="播放"
                app:tint="@color/primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="@color/divider" />

            <ImageButton
                android:id="@+id/route_speed_fab_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_speed"
                android:contentDescription="速度"
                app:tint="@color/primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="@color/divider" />

            <ImageButton
                android:id="@+id/route_stop_fab_btn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_close"
                android:contentDescription="停止"
                app:tint="@color/error" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 地图控制按钮 -->
    <LinearLayout
        android:id="@+id/map_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|center_vertical"
        android:layout_marginEnd="16dp"
        android:orientation="vertical">

        <!-- 路线点编辑按钮容器（默认隐藏） -->
        <LinearLayout
            android:id="@+id/route_point_edit_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageButton
                android:id="@+id/btn_cancel_select"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_map_btn"
                android:src="@drawable/ic_back"
                android:contentDescription="取消选择"
                app:tint="@color/text_primary" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="8dp" />

            <ImageButton
                android:id="@+id/btn_delete_route_point"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_map_btn"
                android:src="@drawable/ic_close"
                android:contentDescription="删除路线点"
                app:tint="@color/text_primary" />

            <Space
                android:layout_width="wrap_content"
                android:layout_height="8dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/zoom_in_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_map_btn"
            android:src="@drawable/ic_add"
            app:tint="@color/text_primary" />

        <Space
            android:layout_width="wrap_content"
            android:layout_height="8dp" />

        <ImageButton
            android:id="@+id/zoom_out_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_map_btn"
            android:src="@drawable/ic_remove"
            app:tint="@color/text_primary" />

        <Space
            android:layout_width="wrap_content"
            android:layout_height="8dp" />

        <ImageButton
            android:id="@+id/location_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_map_btn_primary"
            android:src="@drawable/ic_my_location"
            app:tint="@android:color/white" />

        <Space
            android:layout_width="wrap_content"
            android:layout_height="8dp" />

        <ImageButton
            android:id="@+id/layer_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_map_btn"
            android:src="@drawable/ic_layers"
            app:tint="@color/text_primary" />
    </LinearLayout>

    <!-- FAB 按钮（调整位置以适应Tab） -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="160dp"
        android:src="@drawable/ic_position"
        app:backgroundTint="@color/primary"
        app:tint="@android:color/white"
        app:elevation="8dp"
        app:shapeAppearanceOverlay="@style/CircularFAB" />

    <!-- BottomSheet 面板 -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        android:paddingBottom="80dp"
        app:behavior_hideable="false"
        app:behavior_peekHeight="120dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- 拖拽手柄 -->
        <View
            android:id="@+id/drag_handle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_drag_handle" />

        <!-- Tab 切换器 -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/panel_tabs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@color/surface"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabIndicatorColor="@color/primary"
            app:tabIndicatorHeight="3dp"
            app:tabSelectedTextColor="@color/primary"
            app:tabTextColor="@color/text_secondary"
            app:tabIndicatorFullWidth="true"
            app:tabRippleColor="@android:color/transparent">

            <com.google.android.material.tabs.TabItem
                android:text="@string/tab_single_point" />

            <com.google.android.material.tabs.TabItem
                android:text="@string/tab_route_simulation" />
        </com.google.android.material.tabs.TabLayout>

        <!-- TabLayout 底部边框 -->
        <View
            android:id="@+id/tab_layout_divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@color/divider" />

        <!-- 位置信息卡片 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/location_info_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/primary"
            app:cardCornerRadius="16dp"
            app:strokeWidth="0dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 标题栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/current_location"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:alpha="0.9" />

                    <LinearLayout
                        android:id="@+id/status_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_status_badge"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/bg_status_dot" />

                        <TextView
                            android:id="@+id/status_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:textColor="@android:color/white"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 坐标信息 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/latitude"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:alpha="0.8" />

                        <TextView
                            android:id="@+id/latitude_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="39.9042°"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/longitude"
                            android:textColor="@android:color/white"
                            android:textSize="12sp"
                            android:alpha="0.8" />

                        <TextView
                            android:id="@+id/longitude_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="116.4074°"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 地址信息 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_place"
                        app:tint="@android:color/white" />

                    <TextView
                        android:id="@+id/address_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="北京市东城区天安门广场"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:alpha="0.9"
                        android:singleLine="true"
                        android:ellipsize="marquee"
                        android:marqueeRepeatLimit="marquee_forever"
                        android:focusable="true"
                        android:focusableInTouchMode="true"
                        android:scrollHorizontally="true" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- 单点模式按钮组 -->
        <LinearLayout
            android:id="@+id/point_action_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/input_coords_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_ripple_rounded"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_edit_location"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/input_coords"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/history_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_ripple_rounded"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_history"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/history"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/favorite_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_ripple_rounded"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_favorite"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/favorite"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <LinearLayout
                android:id="@+id/route_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_ripple_rounded"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_route"
                    app:tint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="路线"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ✅ 路线控制面板（精简布局，与4个按钮高度一致） -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/route_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="80dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp">

                <!-- 进度条行 -->
                <LinearLayout
                    android:id="@+id/route_progress_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ProgressBar
                        android:id="@+id/route_progress"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="6dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="0"
                        android:progressTint="@color/primary"
                        android:progressBackgroundTint="@color/divider" />

                    <TextView
                        android:id="@+id/route_point_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="0 个点"
                        android:textColor="@color/text_hint"
                        android:textSize="11sp" />
                </LinearLayout>

                <!-- 控制按钮行（7个元素平均分配） -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <!-- 速度选择器 -->
                    <com.google.android.material.chip.Chip
                        android:id="@+id/speed_0_5x"
                        style="@style/Widget.VirtualLocation.Chip.Speed"
                        android:layout_width="0dp"
                        android:layout_height="26dp"
                        android:layout_weight="1"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:text=".5x" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/speed_1x"
                        style="@style/Widget.VirtualLocation.Chip.Speed"
                        android:layout_width="0dp"
                        android:layout_height="26dp"
                        android:layout_weight="1"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:text="1x"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/speed_2x"
                        style="@style/Widget.VirtualLocation.Chip.Speed"
                        android:layout_width="0dp"
                        android:layout_height="26dp"
                        android:layout_weight="1"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:text="2x" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/speed_4x"
                        style="@style/Widget.VirtualLocation.Chip.Speed"
                        android:layout_width="0dp"
                        android:layout_height="26dp"
                        android:layout_weight="1"
                        android:layout_marginStart="2dp"
                        android:layout_marginEnd="2dp"
                        android:text="4x" />

                    <!-- 移动模式切换按钮 -->
                    <ImageButton
                        android:id="@+id/route_movement_mode_btn"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_walk"
                        android:contentDescription="移动模式"
                        app:tint="@color/primary" />

                    <!-- 循环按钮 -->
                    <ImageButton
                        android:id="@+id/route_loop_btn"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_loop"
                        android:contentDescription="循环"
                        app:tint="@color/text_hint" />

                    <!-- 清除按钮 -->
                    <ImageButton
                        android:id="@+id/route_clear_btn"
                        android:layout_width="0dp"
                        android:layout_height="28dp"
                        android:layout_weight="1"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_delete"
                        android:contentDescription="清除"
                        app:tint="@color/error" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- 底部导航栏 -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/background"
        style="@style/BottomNavigationViewStyle"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 坐标输入对话框主题 - 夜间模式：使用深色背景 -->
    <style name="InputCoordsDialogTheme" parent="Theme.Material3.Dark.Dialog.Alert">
        <!-- 对话框背景色 - 使用项目的surface深色 -->
        <item name="colorSurface">@color/surface</item>
        <item name="android:colorBackground">@color/surface</item>
        <item name="android:windowBackground">@color/surface</item>
        <!-- 按钮文字颜色 -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnSurface">@color/text_secondary</item>
        <!-- 按钮背景色 - 使用深色变体 -->
        <item name="materialButtonStyle">@style/InputCoordsDialogButton</item>
        <!-- 确保标题区域也是深色 -->
        <item name="colorOnBackground">@color/text_primary</item>
    </style>

    <!-- 坐标输入对话框按钮样式 - 夜间模式 -->
    <style name="InputCoordsDialogButton" parent="Widget.Material3.Button.TextButton.Dialog">
        <!-- 按钮背景 - 深色变体 -->
        <item name="backgroundTint">@color/surface_variant</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>

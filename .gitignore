# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/
release/

# Gradle files
.gradle/
build/

# Local configuration file (sdk path, etc) - contains API Keys, MUST NOT commit
local.properties
*.properties.bak

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# Android Studio / IntelliJ
.idea/
# Preserve shared IDE configs for contributors
!.idea/codeStyles/
!.idea/inspectionProfiles/
!.idea/runConfigurations/

# Keystore files - signing keys MUST NOT be committed
*.jks
*.keystore
*.p12
*.pem
keys/

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild
.cxx/

# Google Services (e.g. APIs or Firebase)
google-services.json

# Freeline
freeline.py
freeline/
freeline_project_description.json

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
fastlane/readme.md

# Version control
vcs.xml

# lint
lint/intermediates/
lint/generated/
lint/outputs/
lint/tmp/
lint/reports/

# Kotlin compilation
*.kotlin_module

# AI assistant memory - do not commit AI assistant caches
.workbuddy/
.arts/
AGENTS.md

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Windows reserved device names (accidentally created by some tools)
nul

# Editor / backup files
*~
*.swp
*.swo

# Sensitive data
.env
.env.local
.env.*.local
secrets/
credentials/
api-keys.txt

# Temporary documentation files - moved to docs/ directory
# These are development notes and reports, not needed in version control
docs/
CODE_WIKI.md
REFACTOR_PLAN.md

# Temporary build scripts and guides
*.bat
!gradlew.bat
*_GUIDE.md
*_SPEC.md
DESIGN_*.md
PLAN_*.md
TODO_*.md
*_preview.html
!README.md
!CHANGELOG.md
